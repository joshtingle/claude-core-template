# Copy to .env and fill in real values. Never commit .env.
# All values below are used by app/backend; the frontend reads VITE_FA_KIT_URL
# at build time via app/frontend/index.html.

# Backend port and CORS origin (use * for local dev)
PORT=3001
FRONTEND_URL=*

# Snowflake connection -- only required if the snapshot job runs locally.
# In production the snapshot runs via CI and only the blob connection is needed.
SNOWFLAKE_ACCOUNT=
SNOWFLAKE_USERNAME=
SNOWFLAKE_PASSWORD=
SNOWFLAKE_WAREHOUSE=
SNOWFLAKE_DATABASE=
SNOWFLAKE_SCHEMA=
SNOWFLAKE_ROLE=

# Azure Blob Storage -- only required in production (or to test blob sync locally).
# Container 'snapshots' must contain a private blob 'snapshot.db'.
# When unset, blobSync is a no-op and the app reads the local snapshot only.
AZURE_STORAGE_CONNECTION_STRING=

# Cron schedule for local-dev snapshot runs (server.js scheduler). Default is hourly.
SNAPSHOT_CRON=0 * * * *

# Font Awesome Pro kit URL -- used by app/frontend/index.html.
# Get this from fontawesome.com/kits, then add your deployed domain to the kit settings.
VITE_FA_KIT_URL=
